      "description": "Orange — warm, energetic, playful"
    },
    "Crimson": {
      "base": "#F43F5E",
      "glow": "rgba(244,63,94,0.35)",
      "text": "#FFFFFF",
      "bg":   "rgba(244,63,94,0.10)",
      "description": "Red — urgent, powerful, destructive"
    },
    "Spearmint": {
      "base": "#10B981",
      "glow": "rgba(16,185,129,0.35)",
      "text": "#0A0A0B",
      "bg":   "rgba(16,185,129,0.10)",
      "description": "Emerald — success, health, positive"
    },
    "Solar": {
      "base": "#FACC15",
      "glow": "rgba(250,204,21,0.35)",
      "text": "#0A0A0B",
      "bg":   "rgba(250,204,21,0.10)",
      "description": "Yellow — attention, warmth, optimism"
    }
  }
}
