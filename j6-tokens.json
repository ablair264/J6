  "semantic": {
    "background": {
      "bg-base":     { "light": "#F4F2EE",           "dark": "#0A0A0B",           "description": "Page background" },
      "bg-subtle":   { "light": "#E8E5E0",           "dark": "#111113",           "description": "Slightly raised surface" },
      "bg-surface":  { "light": "#FAFAF9",           "dark": "#141416",           "description": "Card / panel background" },
      "bg-elevated": { "light": "#FFFFFF",           "dark": "#1A1A1D",           "description": "Elevated modal / popover" },
      "bg-overlay":  { "light": "rgba(0,0,0,0.48)",  "dark": "rgba(0,0,0,0.72)",  "description": "Dialog overlay" }
    },
    "border": {
      "border-subtle":  { "light": "rgba(0,0,0,0.07)",    "dark": "rgba(255,255,255,0.06)", "description": "Faintest dividers" },
      "border-default": { "light": "rgba(0,0,0,0.12)",    "dark": "rgba(255,255,255,0.10)", "description": "Standard borders" },
      "border-strong":  { "light": "rgba(0,0,0,0.22)",    "dark": "rgba(255,255,255,0.18)", "description": "Emphasis borders" },
      "border-focus":   { "light": "#D4890A",              "dark": "#F5A623",               "description": "Focus ring" }
    },
    "text": {
      "text-primary":   { "light": "#1A1A1D",  "dark": "#F0EDE8",  "description": "Primary body text" },
      "text-secondary": { "light": "#5A5A64",  "dark": "#9A9AA3",  "description": "Supporting text" },
      "text-muted":     { "light": "#8A8A94",  "dark": "#6B6B72",  "description": "Placeholder, disabled" },
      "text-inverse":   { "light": "#F0EDE8",  "dark": "#0A0A0B",  "description": "Text on dark / accent bg" },
      "text-link":      { "light": "#D4890A",  "dark": "#F5A623",  "description": "Links & inline CTAs" }
    },
    "brand": {
      "brand-default": { "light": "#D4890A",                   "dark": "#F5A623",                   "description": "Primary CTA, brand mark" },
      "brand-hover":   { "light": "#F5A623",                   "dark": "#FFBA4A",                   "description": "CTA hover state" },
      "brand-subtle":  { "light": "rgba(212,137,10,0.10)",     "dark": "rgba(245,166,35,0.12)",     "description": "Tinted bg for brand context" },
      "brand-glow":    { "light": "rgba(212,137,10,0.20)",     "dark": "rgba(245,166,35,0.25)",     "description": "Glow / shadow for brand elements" }
    },
    "interactive": {
      "interactive-default": { "light": "#6D28D9",               "dark": "#7C3AED",               "description": "Links, selected states" },
      "interactive-hover":   { "light": "#7C3AED",               "dark": "#9F72FF",               "description": "Hover on interactive element" },
      "interactive-subtle":  { "light": "rgba(109,40,217,0.10)", "dark": "rgba(124,58,237,0.15)", "description": "Tinted background" }
    },
    "status": {
      "status-success": { "light": "#059669",  "dark": "#34D399",  "description": "Success states" },
      "status-warning": { "light": "#CA8A04",  "dark": "#FACC15",  "description": "Warning states" },
      "status-error":   { "light": "#E11D48",  "dark": "#FB7185",  "description": "Error / destructive" },
      "status-info":    { "light": "#0284C7",  "dark": "#38BDF8",  "description": "Informational" }
    }
  },

  "showcase": {
    "Electric": {
      "base": "#22D3EE",
      "glow": "rgba(34,211,238,0.35)",
      "text": "#0A0A0B",
      "bg":   "rgba(34,211,238,0.10)",
      "description": "Cyan — high energy, data, tech"
    },
    "Bloom": {
      "base": "#F472B6",
      "glow": "rgba(244,114,182,0.35)",
      "text": "#0A0A0B",
      "bg":   "rgba(244,114,182,0.10)",
      "description": "Pink — expressive, creative, bold"
    },
    "Acid": {
      "base": "#A3E635",
      "glow": "rgba(163,230,53,0.35)",
      "text": "#0A0A0B",
      "bg":   "rgba(163,230,53,0.10)",
      "description": "Lime — sharp, modern, high contrast"
    },
    "Plasma": {
      "base": "#818CF8",
      "glow": "rgba(129,140,248,0.35)",
      "text": "#0A0A0B",
      "bg":   "rgba(129,140,248,0.10)",
      "description": "Indigo — cool, trustworthy, premium"
    },
    "Inferno": {
      "base": "#FB923C",
      "glow": "rgba(251,146,60,0.35)",
